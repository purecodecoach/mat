{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "webpack": true,
    "assets": ["service/mail/templates/**/*", "views/**/*", "public/**/*", "service/mail/templates/**/*.hbs"],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": false
  }
}
